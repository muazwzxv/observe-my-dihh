DB_HOST=localhost
DB_PORT=3306
DB_USER=otel_api_demo_user
DB_PASSWORD=otel_api_demo_pass
DB_NAME=otel_api_demo_db
SERVER_PORT=8080
REDIS_HOST=localhost
REDIS_PORT=6379
KAFKA_HOST=localhost
KAFKA_PORT=9092

# Timeouts (duration format: 5s, 1m, etc.)
READ_TIMEOUT=5s
WRITE_TIMEOUT=10s
IDLE_TIMEOUT=0s

# OpenTelemetry
OTEL_SERVICE_NAME=otel_api_demo
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
